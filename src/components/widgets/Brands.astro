---
import type { Brands as Props } from '~/types';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const {
  title = '',
  subtitle = '',
  tagline = '',
  images = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="flex flex-col items-center gap-y-12">
    <div class="flex flex-wrap items-center justify-center gap-x-12 sm:gap-x-20">
      {
        images.slice(0, 2).map((image, index) => {
          const imageSrc = typeof image.src === 'string' ? image.src : image.src?.src;

          // 파나소닉(index 0)은 h-12~20 정도로, 텍넥(index 1)은 h-24~28 정도로 개별 설정
          const sizeClass =
            index === 0
              ? 'h-12 sm:h-16 md:h-20' // 파나소닉 (기존보다 약 30% 축소)
              : 'h-16 sm:h-24 md:h-28'; // 텍넥 (기존 큰 크기 유지)

          return (
            <div class="flex items-center justify-center p-2">
              <img src={imageSrc} alt={image.alt || ''} class={`${sizeClass} w-auto object-contain`} />
            </div>
          );
        })
      }
    </div>

    <div class="flex flex-wrap items-center justify-center gap-x-10 sm:gap-x-16">
      {
        images.slice(2, 4).map((image) => {
          const imageSrc = typeof image.src === 'string' ? image.src : image.src?.src;
          return (
            <div class="flex items-center justify-center p-2">
              <img src={imageSrc} alt={image.alt || ''} class="object-contain w-auto h-10 sm:h-12" />
            </div>
          );
        })
      }
    </div>
  </div>
</WidgetWrapper>
