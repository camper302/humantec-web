---
import Layout from '~/layouts/PageLayout.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import ProcessGrid from '~/components/widgets/ProcessGrid.astro';
import Brands from '~/components/widgets/Brands.astro';
import logoPanasonic from '~/assets/images/logo_panasonic.svg';
import logoNewccess from '~/assets/images/logo_newccess.png';
import logoTeknek from '~/assets/images/logo_teknek.png';
import logoCedatec from '~/assets/images/logo_cedatec.png';

const brandImages = [
  {
    src: logoPanasonic,
    alt: 'Panasonic',
    href: 'https://industrial.panasonic.com/kr/products/pt/megtron',
  },
  {
    src: logoTeknek,
    alt: 'Teknek',
    href: 'https://www.teknek.com/',
  },
  {
    src: logoNewccess,
    alt: 'Newccess',
    href: 'https://www.newccess.com/',
  },
  {
    src: logoCedatec,
    alt: 'Cedatec',
    href: 'https://www.cedatec.it/',
  },
];

const metadata = {
  title: 'Humantech Web Site',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero>
    <Fragment slot="actions">
      <div class="flex flex-col max-w-xs gap-4 m-auto sm:max-w-md flex-nowrap sm:flex-row sm:justify-center">
        <!-- Products -->
        <a href={getPermalink('/services')} class="w-full btn-primary sm:w-auto"> Products </a>

        <!-- About Us -->
        <a
          href={getPermalink('/homes/personal')}
          class="inline-flex items-center justify-center rounded-full border border-white bg-transparent text-white font-semibold py-3.5 px-8 hover:bg-white/10 transition"
        >
          About Us
        </a>
      </div>
    </Fragment>
    <!-- VIDEO BACKGROUND -->
    <Fragment slot="bg">
      <div class="absolute inset-x-0 bottom-0 top-[72px] md:top-[76px] overflow-hidden">
        <!-- Video 1 -->
        <video class="hero-video" autoplay muted loop playsinline>
          <source src="/videos/slide1.mp4" type="video/mp4" />
        </video>

        <!-- Video 2 -->
        <video class="hero-video" autoplay muted loop playsinline>
          <source src="/videos/slide2.mp4" type="video/mp4" />
        </video>

        <!-- Video 3 -->
        <video class="hero-video" autoplay muted loop playsinline>
          <source src="/videos/slide3.mp4" type="video/mp4" />
        </video>

        <!-- Dark Overlay -->
        <div class="absolute inset-0 bg-black/50"></div>
      </div>

      <script is:inline>
        // 전역 변수로 타이머 ID를 관리하여 중복 생성을 방지합니다.
        let heroSliderInterval;

        const initHeroSlider = () => {
          const videos = document.querySelectorAll('.hero-video');
          const titles = document.querySelectorAll('.hero-title');

          if (!videos.length) return;

          // 1. 기존 타이머가 돌고 있다면 초기화 (페이지 왕복 시 충돌 방지)
          if (heroSliderInterval) {
            clearInterval(heroSliderInterval);
          }

          let current = 0;

          const showSlide = (index) => {
            videos.forEach((el, i) => {
              el.style.opacity = i === index ? '1' : '0';

              // 2. 화면에 표시되는 비디오는 명시적으로 재생(play)시킵니다.
              if (i === index) {
                // DOM 교체 후 브라우저 정책에 의해 autoplay가 씹히는 것을 방지
                el.play().catch((err) => console.log('Video autoplay prevented:', err));
              } else {
                // 리소스 최적화를 위해 보이지 않는 비디오는 일시정지합니다.
                el.pause();
                el.currentTime = 0; // 처음부터 다시 재생되도록 초기화 (원치 않으시면 삭제 가능)
              }
            });

            titles.forEach((el, i) => {
              el.style.opacity = i === index ? '1' : '0';
            });
          };

          // 초기 첫 번째 슬라이드 강제 실행
          showSlide(0);

          // 3. 새로운 타이머 시작 및 할당
          heroSliderInterval = setInterval(() => {
            current = (current + 1) % videos.length;
            showSlide(current);
          }, 7000);
        };

        // 초기 로드 및 뒤로가기/페이지 이동 복귀 시 실행
        document.addEventListener('astro:page-load', initHeroSlider);

        // 페이지를 떠나기 직전에 메모리 누수를 막기 위해 타이머 정리
        document.addEventListener('astro:before-swap', () => {
          if (heroSliderInterval) {
            clearInterval(heroSliderInterval);
          }
        });
      </script>

      <style is:global>
        .hero-video {
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          opacity: 0;
          transition: opacity 1.2s ease;
        }

        .hero-title {
          opacity: 0;
          transition: opacity 1s ease;
        }

        .hero-title:first-child {
          opacity: 1;
        }
      </style>
    </Fragment>

    <!-- TITLE ONLY -->
    <!-- TITLE ONLY -->
    <Fragment slot="title">
      <div class="relative min-h-[220px] md:min-h-[180px] flex items-center justify-center">
        <!-- Slide 1 -->
        <div class="absolute inset-0 flex items-center justify-center px-4 text-center hero-title sm:px-6">
          <h1 class="text-4xl font-bold leading-tight text-white sm:text-5xl md:text-6xl drop-shadow-lg">
            Connecting Human and Tech
            <!-- <span class="hidden xl:inline"> Materials & Equipment </span>
            <br />
            Partner for Future Electronics -->
          </h1>
        </div>

        <!-- Slide 2 -->
        <div class="absolute inset-0 flex items-center justify-center px-4 text-center hero-title sm:px-6">
          <h1 class="text-4xl font-bold leading-tight text-white sm:text-5xl md:text-6xl drop-shadow-lg">
            Advanced PCB Solutions
            <!-- <span class="hidden xl:inline"> Manufacturing Solutions </span>
            <br />
            for Global Industry -->
          </h1>
        </div>

        <!-- Slide 3 -->
        <div class="absolute inset-0 flex items-center justify-center px-4 text-center hero-title sm:px-6">
          <h1 class="text-4xl font-bold leading-tight text-white sm:text-5xl md:text-6xl drop-shadow-lg">
            Synergy with Global Network
            <!-- <span class="hidden xl:inline"> for Smart Electronics </span>
            <br />
            and Innovation -->
          </h1>
        </div>
      </div>
    </Fragment>
  </Hero>

  <!-- Problem / Solution Section **************** -->

  <!-- Problem (왼쪽) -->
