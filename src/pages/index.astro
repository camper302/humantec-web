    title="Challenges"
    subtitle="초고속 고용량 데이터 전송이 필요한 AI 서버향 PCB 에서 발생하는 주요 이슈"
    classes={{
      container: 'py-12 md:py-16', // 기존 간격 유지용 (선택사항)
      items: {
        icon: 'text-red-500', // ✅ 체크 아이콘을 빨간색으로 변경
      },
    }}
    items={[
