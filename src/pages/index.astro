---
import Layout from '~/layouts/PageLayout.astro';
import Brands from '~/components/widgets/Brands.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Products',
        href: getPermalink('/services'),
        // target: '_blank',
        // icon: 'tabler:download',
      },
      { text: 'About Us', href: getPermalink('/homes/personal') },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'AstroWind Hero Image' }}
  >
    <Fragment slot="title">
      High-Tech <span class="hidden xl:inline">Materials & Equipment</span>
      Partner for Future Electronics
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">휴먼텍은</span> 글로벌 소재, 장비 기술력을 국내 PCB 산업에 연결하는 최적의 솔루션 파트너입니다.</span
      >
      <!-- <span class="block mb-1 font-bold text-blue-600 sm:hidden">AstroWind: Production-ready.</span>
      Suitable for Startups, Small Business, SaaS websites, Professional Portfolios, Marketing websites, Landing Pages &
      Blogs. -->
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Philosophy:" description="Simplicity, Best Practices and High Performance" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Target Market"
    title="Main business areas"
    subtitle="PCB 분야에 있어 소재(Material), 소모품(Consumables), 장비(Machinery)를 아우르는 통합 솔루션 프로바이더"
    items={[
      {
        title: '반도체 / IC Substrate',
        description: '삼성전자, SK하이닉스향 반도체 테스트 기판(Probe Card) 및 고사양 패키지 기판용 소재 공급.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: '전장(Automotive)',
        description: '자율주행 센서, BMS, ECU용 고내열/고신뢰성 할로겐 프리 소재(R-1566 등) 공급.',
        icon: 'tabler:components',
      },
      {
        title: '디스플레이/모바일',
        description: 'LG디스플레이, 삼성SDI 및 BOE/CSOT 등 글로벌 기업에 세정 장비 및 FPCB 소재 공급.',
        icon: 'tabler:list-check',
      },
      {
        title: '5G/6G 통신 인프라 / AI 서버',
        description: 'AI 가속기, 차세대 데이터 센터 인프라, 5G 기지국, 고성능 라우터',
        icon: 'tabler:rocket',
      },
      // {
      //   title: 'Search Engine Optimization (SEO)',
      //   description:
      //     "SEO lies in its ability to enhance a website's visibility, driving organic traffic and enabling it to reach a wider audience.",
      //   icon: 'tabler:arrows-right-left',
      // },
      // {
      //   title: 'Open to new ideas and contributions',
      //   description:
      //     'Embracing a culture that is open to new ideas and contributions is integral fostering innovation, collaboration, and a dynamic user experience.',
      //   icon: 'tabler:bulb',
      // },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Solution"
    title="Business Model"
    items={[
      {
        title: '공정 최적화 솔루션',
        description: '설계 단계부터 참여하는 Design-in 기반 컨설팅으로 귀사의 생산 수율을 높입니다.',
      },
      {
        title: '안정적 인프라 지원',
        description: '장비부터 필수 소모품까지, 끊김 없는 공급망 관리로 비즈니스의 연속성을 보장합니다.',
      },
      {
        title: '신속한 기술 대응',
        description: '글로벌 표준에 맞춘 기술 지원과 장애 대응으로 외산 장비 운영의 부담을 덜어드립니다.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <!-- <Fragment slot="content">
      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">Building on modern foundations</h3>
      Gain a competitive advantage by incorporating industry leading practices
    </Fragment> -->

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>
  <!-- Stats Widget ****************** -->

  <Stats
    title="Discover the impressive impact of Astrowind"
    subtitle="The numbers below reflect the trust our users have placed in us and the remarkable outcomes we've helped them achieve."
    stats={[
      { title: 'Downloads', amount: '182K' },
      { title: 'Websites Launched', amount: '87' },
      { title: 'User Ratings', amount: '4.8' },
      { title: 'Satisfied Clients', amount: '116K' },
    ]}
  />

  <!-- Brands Widget ****************** -->

  <Brands
    title="Partnerships & Collaborations"
    subtitle="At Astrowind, we believe in the power of collaboration to drive innovation and create exceptional experiences."
    icons={[]}
    images={[
      {
        src: '~/assets/images/logo_panasonic.png',
        alt: 'Paypal',
      },
      {
        src: '~/assets/images/logo_newccess.png',
        alt: 'Visa',
      },
      {
        src: '~/assets/images/logo_teknek.png',
        alt: 'Ebay',
      },

      {
        src: '~/assets/images/logo_cedatec.png',
        alt: 'Youtube',
      },
      {
        src: '~/assets/images/logo_jcc.png',
        alt: 'Microsoft',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get template',
        href: 'https://github.com/arthelokyo/astrowind',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      Astro&nbsp;+&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Tailwind CSS</span>
    </Fragment>

    <Fragment slot="subtitle">
      Be very surprised by these huge fake numbers you are seeing on this page. <br class="hidden md:inline" />Don't
      waste more time! :P
    </Fragment>
  </CallToAction>
</Layout>
