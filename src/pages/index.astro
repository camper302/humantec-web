---
import Layout from '~/layouts/PageLayout.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import ProcessGrid from '~/components/widgets/ProcessGrid.astro';
import Brands from '~/components/widgets/Brands.astro';
import logoPanasonic from '~/assets/images/logo_panasonic.svg';
import logoNewccess from '~/assets/images/logo_newccess.png';
import logoTeknek from '~/assets/images/logo_teknek.png';
import logoCedatec from '~/assets/images/logo_cedatec.png';

const brandImages = [
  {
    src: logoPanasonic,
    alt: 'Panasonic',
    href: 'https://industrial.panasonic.com/kr/products/pt/megtron',
  },
  {
    src: logoTeknek,
    alt: 'Teknek',
    href: 'https://www.teknek.com/',
  },
  {
    src: logoNewccess,
    alt: 'Newccess',
    href: 'https://www.newccess.com/',
  },
  {
    src: logoCedatec,
    alt: 'Cedatec',
    href: 'https://www.cedatec.it/',
  },
];

const metadata = {
  title: 'Humantech Web Site',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Products',
        href: getPermalink('/services'),
        // target: '_blank',
        // icon: 'tabler:download',
      },
      { text: 'About Us', href: getPermalink('/homes/personal') },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'PCB' }}
  >
    <Fragment slot="title">
      High-Tech <span class="hidden xl:inline">Materials & Equipment</span>
      Partner for Future Electronics
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">휴먼텍은</span> 글로벌 소재, 장비 기술력을 국내 PCB 산업에 연결하는 최적의 솔루션 파트너입니다.</span
      >
      <!-- <span class="block mb-1 font-bold text-blue-600 sm:hidden">AstroWind: Production-ready.</span>
      Suitable for Startups, Small Business, SaaS websites, Professional Portfolios, Marketing websites, Landing Pages &
      Blogs. -->
    </Fragment>
  </Hero>

  <!-- Problem / Solution Section **************** -->

  <!-- Problem (왼쪽) -->
  <Content
    tagline="Challenges"
    title="Key Challenges in Advanced PCB Manufacturing"
    subtitle="고난이도 PCB 공정에서 발생하는 주요 문제"
    classes={{
      container: 'py-12 md:py-16', // 기존 간격 유지용 (선택사항)
      items: {
        icon: 'text-red-500', // ✅ 체크 아이콘을 빨간색으로 변경
      },
    }}
    items={[
      {
        title: '고주파 신호 손실',
        description: '고속·고주파 환경에서 신호 감쇄 및 데이터 무결성 저하 발생',
        classes: {
          icon: 'text-white bg-red-500 dark:bg-red-700 rounded-full p-1',
        },
      },
      {
        title: '다층 PCB 정렬 문제',
        description: '고다층 기판에서 미세 정렬 오차로 인한 불량 발생',
        classes: {
          icon: 'text-white bg-red-500 dark:bg-red-700 rounded-full p-1',
        },
      },
      {
        title: '파티클 및 오염 이슈',
        description: '초미세 공정에서 미세 오염이 수율 저하로 직결',
        classes: {
          icon: 'text-white bg-red-500 dark:bg-red-700 rounded-full p-1',
        },
      },
      {
        title: '초기 양산 수율 불안정',
        description: '신규 공정 도입 시 수율 안정화까지 긴 시간 소요',
        classes: {
          icon: 'text-white bg-red-500 dark:bg-red-700 rounded-full p-1',
        },
      },
    ]}
    image={{
      src: '~/assets/images/problem.png',
      alt: 'PCB Challenges',
    }}
  >
    <Fragment slot="content">
      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Manufacturing Complexity is Increasing
      </h3>
      첨단 PCB 공정은 점점 더 높은 정밀도와 신뢰성을 요구하고 있으며, 기존 방식으로는 한계에 도달하고 있습니다.
    </Fragment>
    <!-- 
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-red-50 dark:bg-transparent"></div>
    </Fragment> -->
  </Content>

  <!-- Solution (오른쪽) -->
  <Content
    isReversed
    isAfterContent
    tagline="Solution"
    title="How We Solve These Challenges"
    subtitle="휴먼텍의 통합 솔루션으로 PCB 공정의 한계를 극복합니다"
    items={[
      {
        title: '고속·저손실 소재 기술',
        description: 'MEGTRON 기반 초저유전 소재로 고주파 신호 손실 최소화',
      },
      {
        title: '정밀 정렬 솔루션',
        description: 'Pinless 광학 정렬 기술로 고다층 PCB 정밀도 확보',
      },
      {
        title: '파티클 제어 시스템',
        description: 'Teknek 기반 클리닝 솔루션으로 오염 최소화',
      },
      {
        title: '통합 공급망 및 기술 지원',
        description: '소재·장비·소모품 One-stop 제공 및 빠른 기술 대응',
      },
    ]}
    image={{
      src: '~/assets/images/solution.png',
      alt: 'PCB Solutions',
    }}
  >
    <Fragment slot="content">
      <p class="mb-4 font-semibold text-blue-600">→ 휴먼텍은 이러한 문제를 해결합니다</p>

      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Integrated Solution for Advanced PCB Manufacturing
      </h3>

      소재(Material), 장비(Machinery), 소모품(Consumables)을 통합하여 공정 최적화와 수율 향상을 동시에 실현합니다.
    </Fragment>

    <!-- <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment> -->
  </Content>

  <!-- Note Widget ******************* -->

  <Note
    title="Product Lineup:"
    description=" CCL, Prepreg, Copper Foil, Drilling Board, Contact Cleaning System, Pinless Bonder System"
  />

  <!-- Features Widget *************** -->

  <ProcessGrid
    title="PCB Manufacturing Process "
    subtitle="휴먼텍은 첨단 PCB 제조 공정에 필요한 소재(Material), 소모품(Consumables), 장비(Machinery)를 아우르는 통합 솔루션 프로바이더 입니다."
    items={[
      {
        title: '1. Lamination',
        description: '내층회로가 형성된 원자재(CCL)와 절연체(prepreg) 를 열과 압력을 사용하여 접합시키는 공정.',
        image: { src: '~/assets/images/step1.png', alt: 'Lamination' },
      },
      {
        title: '2. Drilling',
        description: '내층과 외층 간의 전기적 접속을 할 수 있도록 Drill 을 이용하여 hole 을 가공하는 공정',
        image: { src: '~/assets/images/step2.png', alt: 'Drilling' },
      },
      {
        title: '3. Plating',
        description: '제품 표면 및 hole 속을 동으로 도금하여 내층과 외층을 전기적으로 접속 시키는 공정',
        image: { src: '~/assets/images/step3.png', alt: 'Plating' },
      },
      {
        title: '4. Circuit Formation',
        description:
          '동도금 처리된 panel에 외층 회로를 형성하는 공정으로 노광 > 현상 > 부식 공정을 거쳐 회로를 형성하는 공정',
        image: { src: '~/assets/images/step4.png', alt: 'Circuit' },
      },
      {
        title: '5. Surface Treatment',
        description:
          '불변성 잉크를 사용하여 비활용 영역을 코팅, 산화방지 및 SMT 용이성을 위한 활용 영역 표면을 코팅하는 공정',
        image: { src: '~/assets/images/step5.png', alt: 'Surface' },
      },
      {
        title: '6. Inspection',
        description: '전기적 테스트를 통해 회로 연결 상태를 확인하고 확대경을 이용해 제품의 외관을 확인하는 공정',
        image: { src: '~/assets/images/step6.png', alt: 'Inspection' },
      },
    ]}
  />

  <!-- Brands Widget ****************** -->
  <Brands
    title="Partnerships & Collaborations"
    subtitle="At Astrowind, we believe in the power of collaboration to drive innovation and create exceptional experiences."
    images={brandImages}
  />
  <!-- Features2 Widget ************** -->

  <Features2
    title="Target Market"
    subtitle="대한민국을 대표하는 최첨단 산업 분야의 휴면텍의 소부장 기술이 적용 됩니다."
    tagline="Components"
    columns={2}
    items={[
      {
        title: 'AI 서버 / 5G·6G 통신 인프라',
        description: 'AI 가속기 · 데이터센터 서버 · 5G/6G 기지국 · 고성능 스위치 · 라우터',
        icon: 'tabler:router',
      },
      {
        title: '반도체 / IC Substrate',
        description: 'AI 프로세서 패키지 · FC-BGA 기판 · HBM 인터포저 · 프로브 카드 · 고다층 서버용 substrate',
        icon: 'tabler:cpu',
      },

      {
        title: '전장 (Automotive)',
        description: 'BMS · 인버터 · ADAS · 차량용 레이더 · 인포테인먼트 시스템',
        icon: 'tabler:car',
      },
      {
        title: '디스플레이 / 모바일',
        description: 'OLED · Micro LED · 폴더블 디스플레이 · 스마트폰 메인보드 · 웨어러블 디바이스',
        icon: 'tabler:device-mobile',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Steps2
    title="Our values"
    subtitle="설계에서 양산까지, 공정의 빈틈을 메우고 수율의 가치를 높입니다. 최적화된 Design-in 컨설팅부터 끊김 없는 지원까지, 귀사의 생산 리스크는 최소화하고 제조 경쟁력은 극대화 합니다."
    items={[
      {
        title: 'Design-in 기반 공정 최적화',
        description: '설계 단계 참여형 컨설팅으로 개발 기간 단축 및 초기 양산 수율 안정화 확보',
      },
      {
        title: '안정적 인프라 및 공급망 지원',
        description: '원자재, 장비 및 소모품까지 total 솔루션의 SCM 구축으로 최적의 생산 환경과 원가 경쟁력 보장',
      },
      {
        title: '글로벌 네트워크 중심의 기술 대응',
        description: '글로벌 표준 기반의 신속한 장애 대응과 최적의 솔루션 제공으로 외산 장비 운영 리스크 최소화',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contact Us',
        href: '/contact',
      },
      {
        text: 'Download Catalog',
        href: '/catalog',
      },
    ]}
  >
    <Fragment slot="title"> Let’s Optimize Your PCB Process </Fragment>

    <Fragment slot="subtitle"> 소재, 장비, 공정 기술까지 통합적으로 지원합니다. </Fragment>
  </CallToAction>

  <!-- <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get template',
        href: 'https://github.com/arthelokyo/astrowind',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      Astro&nbsp;+&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Tailwind CSS</span>
    </Fragment>

    <Fragment slot="subtitle">
      Be very surprised by these huge fake numbers you are seeing on this page. <br class="hidden md:inline" />Don't
      waste more time! :P
    </Fragment>
  </CallToAction> -->
</Layout>
